{
	"name": "@aamini/infra",
	"version": "1.0.0",
	"private": true,
	"module": "true",
	"scripts": {
		"lint": "oxlint .",
		"format": "oxfmt --check .",
		"chart:package-check": "helm lint ./charts/app-release && rm -rf /tmp/app-release-chart && helm package ./charts/app-release --destination /tmp/app-release-chart && helm show chart /tmp/app-release-chart/app-release-0.1.0.tgz",
		"chart:publish-oci": "helm package ./charts/app-release --destination /tmp/app-release-chart && helm push /tmp/app-release-chart/app-release-*.tgz oci://ghcr.io/aamini-stack",
		"test": "tsx --test test/**/*.test.ts",
		"typecheck": "tsc --noEmit",
		"verify": "turbo run test typecheck"
	},
	"dependencies": {
		"@pulumi/azure-native": "^3.13.0",
		"@pulumi/command": "^1.1.3",
		"@pulumi/kubernetes": "^4.0.0",
		"@pulumi/local": "^0.1.6",
		"@pulumi/postgresql": "^3.0.0",
		"@pulumi/pulumi": "^3.220.0",
		"@pulumi/random": "^4.0.0",
		"@pulumi/tls": "^5.3.0",
		"yaml": "^2.8.1"
	},
	"devDependencies": {
		"@aamini/config-typescript": "workspace:*",
		"@types/node": "^25.4.0",
		"tsx": "^4.21.0",
		"typescript": "^5.9.3"
	}
}
