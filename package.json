{
	"name": "@aamini/root",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"build": "turbo build",
		"format": "oxfmt --check",
		"format:fix": "oxfmt",
		"typecheck": "turbo run typecheck",
		"lint": "oxlint --type-aware --max-warnings=0",
		"test": "turbo run test",
		"test:unit": "turbo run test:unit",
		"test:integration": "turbo run test:integration",
		"e2e": "turbo run --continue=dependencies-successful e2e",
		"e2e:ci": "turbo run --continue=dependencies-successful e2e:ci",
		"e2e:staging": "turbo run --continue=dependencies-successful e2e:staging",
		"e2e:update": "turbo run --continue=dependencies-successful e2e:update",
		"verify": "turbo run --continue=dependencies-successful build lint format test typecheck",
		"verify:ci": "turbo run --continue=dependencies-successful build lint format test typecheck e2e:ci"
	},
	"devDependencies": {
		"@playwright/test": "^1.59.1",
		"oxfmt": "^0.45.0",
		"oxlint": "^1.53.0",
		"oxlint-tsgolint": "^0.21.1",
		"prettier": "^3.8.1",
		"prettier-plugin-jsdoc": "^1.8.0",
		"prettier-plugin-organize-imports": "^4.3.0",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"tsx": "^4.21.0",
		"turbo": "^2.8.16"
	},
	"engines": {
		"node": ">=22"
	},
	"packageManager": "pnpm@10.33.0+sha512.10568bb4a6afb58c9eb3630da90cc9516417abebd3fabbe6739f0ae795728da1491e9db5a544c76ad8eb7570f5c4bb3d6c637b2cb41bfdcdb47fa823c8649319"
}
