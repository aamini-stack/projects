{
	"name": "@aamini/root",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"scripts": {
		"aamini": "node --experimental-strip-types scripts/src/aamini.ts",
		"build": "turbo build",
		"format": "oxfmt --check",
		"format:fix": "oxfmt",
		"typecheck": "turbo run typecheck",
		"lint": "oxlint --type-aware --max-warnings=0",
		"test": "turbo run test",
		"test:unit": "turbo run test:unit",
		"test:integration": "turbo run test:integration",
		"e2e": "turbo run --continue=dependencies-successful e2e --concurrency 1",
		"e2e:staging": "turbo run --continue=dependencies-successful e2e:staging --concurrency 1",
		"e2e:update": "turbo run --continue=dependencies-successful e2e:update --concurrency 1",
		"verify": "turbo run --continue=dependencies-successful build lint format test typecheck",
		"verify:ci": "turbo run --continue=dependencies-successful build lint format test typecheck e2e:ci"
	},
	"devDependencies": {
		"@playwright/test": "^1.59.1",
		"oxfmt": "^0.45.0",
		"oxlint": "^1.53.0",
		"oxlint-tsgolint": "^0.21.1",
		"prettier": "^3.8.1",
		"prettier-plugin-jsdoc": "^1.8.0",
		"prettier-plugin-organize-imports": "^4.3.0",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"tsx": "^4.21.0",
		"turbo": "^2.8.16"
	},
	"engines": {
		"node": ">=22"
	},
	"packageManager": "pnpm@10.33.1+sha512.05ba3c1d5d1c18f68df06470d74055e62d41fc110a0c660db1b2dfb2785327f04cf0f68345d4609bc52089e7fa0343c31593b2f9594e2c5d5da426230acc9820"
}
