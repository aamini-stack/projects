# Copy this file to .env.local and fill in real values.
# `aamini update-action-secrets` syncs each key to GitHub Actions secrets.

AWS_GITHUB_ACTIONS_ROLE_ARN=arn:aws:iam::123456789012:role/github-actions-role
FLUX_RECEIVER_URL=https://example.com/flux-receiver
GHCR_TOKEN=replace-with-real-token
TURBO_TOKEN=replace-with-real-token
VERCEL_TOKEN=replace-with-real-token
