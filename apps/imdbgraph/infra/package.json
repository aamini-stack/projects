{
	"name": "imdbgraph-infra",
	"main": "index.ts",
	"scripts": {
		"lint": "oxlint .",
		"format": "oxfmt --check .",
		"typecheck": "tsc --noEmit --module esnext --moduleResolution bundler --target es2022 index.ts",
		"preview": "pulumi preview --stack ${PULUMI_STACK:-staging}",
		"verify": "turbo run typecheck preview"
	},
	"dependencies": {
		"@aamini/infra": "workspace:*",
		"@pulumi/azure-native": "^3.13.0",
		"@pulumi/command": "^1.1.3",
		"@pulumi/postgresql": "^3.0.0",
		"@pulumi/pulumi": "^3.220.0"
	}
}
