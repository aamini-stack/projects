{
	"name": "portfolio",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"imports": {
		"#/*": "./src/*"
	},
	"scripts": {
		"build": "vite build",
		"dev": "vite dev --port 3000",
		"serve": "vite preview",
		"start": "node .output/server/index.mjs",
		"typecheck": "tsc --noEmit",
		"lint": "oxlint --type-aware --max-warnings=0",
		"test": "vitest run",
		"test:unit": "vitest run --project unit",
		"test:integration": "vitest run --project browser --project server",
		"test:watch": "vitest --watch",
		"e2e": "node --experimental-strip-types ../../scripts/src/aamini.ts e2e portfolio",
		"e2e:ci": "node --experimental-strip-types ../../scripts/src/aamini.ts e2e portfolio --docker",
		"e2e:staging": "BASE_URL=https://portfolio.ariaamini.com pnpm playwright test",
		"e2e:update": "node --experimental-strip-types ../../scripts/src/aamini.ts e2e portfolio --update-snapshots",
		"report": "playwright show-report",
		"verify": "turbo run build test typecheck e2e"
	},
	"dependencies": {
		"@aamini/ui": "workspace:@aamini/ui-neobrutalist@*",
		"@fontsource-variable/dm-sans": "^5.2.8",
		"@hookform/resolvers": "^5.2.2",
		"@radix-ui/react-accordion": "^1.2.12",
		"@radix-ui/react-collapsible": "^1.1.12",
		"@radix-ui/react-label": "^2.1.8",
		"@radix-ui/react-navigation-menu": "^1.2.14",
		"@radix-ui/react-slot": "^1.2.4",
		"@tanstack/react-query": "^5.90.21",
		"@tanstack/react-router": "^1.166.7",
		"@tanstack/react-router-devtools": "^1.166.7",
		"@tanstack/react-router-ssr-query": "^1.166.7",
		"@tanstack/react-start": "^1.166.7",
		"@tanstack/router-plugin": "^1.166.7",
		"arktype": "^2.2.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"form-data": "^4.0.5",
		"lucide-react": "^1.8.0",
		"mailgun.js": "^13.0.0",
		"nitro": "latest",
		"posthog-js": "^1.369.1",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-hook-form": "^7.71.2",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.5.0",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@aamini/config-testing": "workspace:*",
		"@aamini/config-typescript": "workspace:*",
		"@aamini/config-vite": "workspace:*",
		"@playwright/test": "^1.59.1",
		"@tailwindcss/vite": "^4.2.1",
		"@tanstack/devtools-vite": "^0.6.0",
		"@testing-library/jest-dom": "^6.9.1",
		"@types/node": "^25.4.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@varlock/azure-key-vault-plugin": "^0.0.6",
		"@vitejs/plugin-react": "^6.0.1",
		"@vitest/browser": "^4.1.4",
		"babel-plugin-react-compiler": "^1.0.0",
		"msw": "^2.13.4",
		"tailwindcss": "^4.2.1",
		"tw-animate-css": "^1.4.0",
		"typescript": "6.0.2",
		"varlock": "^0.7.2",
		"vite": "^8.0.8",
		"vite-plugin-svgr": "^5.2.0",
		"vitest": "^4.1.4",
		"vitest-browser-react": "^2.0.5"
	}
}
