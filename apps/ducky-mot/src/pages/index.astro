---
import { getCollection } from 'astro:content'
import Aftermovie from '#/components/aftermovie.astro'
import BusinessInquiries from '#/components/business-inquiries.astro'
import { Events } from '#/components/events'
import Footer from '#/components/footer.astro'
import { Header } from '#/components/header'
import Hero from '#/components/hero.astro'
import OurMission from '#/components/our-mission.astro'
import Layout from '#/pages/_Layout.astro'

// Fetch and group events by year
const allEvents = await getCollection('events')
const eventsByYear = allEvents.reduce(
	(acc, event) => {
		const year = event.data.year
		if (!acc[year]) {
			acc[year] = []
		}
		acc[year].push({
			date: event.data.date,
			title: event.data.title,
			href: event.data.href,
			img: event.data.img,
		})
		return acc
	},
	{} as Record<number, Array<{ date: string; title: string; href: string; img: string }>>,
)

// Convert to array and sort by year descending
const eventGroups = Object.entries(eventsByYear)
	.map(([year, items]) => ({
		year: Number(year),
		items,
	}))
	.sort((a, b) => b.year - a.year)
---

<Layout>
	<!-- Enhanced dark background with multiple layers -->
	<div
		class="fixed inset-0 -z-10 bg-gradient-to-br from-gray-900 via-black to-gray-800"
	>
	</div>
	<div
		class="fixed inset-0 -z-10 bg-gradient-to-t from-black/20 via-transparent to-black/40"
	>
	</div>

	<!-- Main container -->
	<div class="flex min-h-screen flex-col">
		<!-- Header -->
		<Header client:load />

		<main id="content">
			<!-- Hero Section -->
			<Hero />

			<!-- Ducky Events -->
			<Events client:load eventsByYear={eventGroups} />

			<!-- Aftermovie -->
			<Aftermovie />

			<!-- Our Mission -->
			<OurMission />

			<!-- Business Inquiries -->
			<BusinessInquiries />
		</main>

		<!-- Footer -->
		<Footer />
	</div>
</Layout>
