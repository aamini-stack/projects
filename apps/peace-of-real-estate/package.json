{
	"name": "peace-of-real-estate",
	"version": "0.0.1",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "vite dev --port 3000",
		"build": "vite build",
		"serve": "vite preview",
		"start": "node .output/server/index.mjs",
		"typecheck": "tsc --noEmit",
		"lint": "oxlint --type-aware --max-warnings=0",
		"test": "vitest run",
		"test:unit": "vitest run --project unit",
		"test:integration": "vitest run --project browser --project server",
		"test:watch": "vitest --watch",
		"e2e": "node --experimental-strip-types ../../scripts/src/aamini.ts e2e peace-of-real-estate",
		"e2e:ci": "node --experimental-strip-types ../../scripts/src/aamini.ts e2e peace-of-real-estate --docker",
		"e2e:staging": "node --experimental-strip-types ../../scripts/src/aamini.ts e2e peace-of-real-estate --staging",
		"e2e:update": "node --experimental-strip-types ../../scripts/src/aamini.ts e2e peace-of-real-estate --update-snapshots",
		"report": "playwright show-report",
		"verify": "turbo run build test typecheck e2e",
		"populate": "tsx --env-file .env.local scripts/populate-db.ts",
		"db:generate": "drizzle-kit generate",
		"db:migrate": "drizzle-kit migrate",
		"db:push": "drizzle-kit push"
	},
	"dependencies": {
		"@aamini/lib": "workspace:*",
		"@aamini/ui": "workspace:*",
		"@azure/identity": "^4.13.1",
		"@better-auth/drizzle-adapter": "^1.6.5",
		"@fontsource-variable/dm-sans": "^5.2.8",
		"@radix-ui/react-dropdown-menu": "^2.1.16",
		"@radix-ui/react-slot": "^1.2.4",
		"@tanstack/react-devtools": "^0.10.2",
		"@tanstack/react-query": "^5.90.21",
		"@tanstack/react-router": "^1.166.7",
		"@tanstack/react-router-devtools": "^1.166.7",
		"@tanstack/react-router-ssr-query": "^1.166.7",
		"@tanstack/react-start": "^1.166.7",
		"@tanstack/router-plugin": "^1.166.7",
		"better-auth": "^1.6.5",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"cmdk": "^1.1.1",
		"lucide-react": "^1.8.0",
		"nitro": "latest",
		"posthog-js": "^1.369.1",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"tailwind-merge": "^3.5.0"
	},
	"devDependencies": {
		"@aamini/config-testing": "workspace:*",
		"@aamini/config-typescript": "workspace:*",
		"@aamini/config-vite": "workspace:*",
		"@playwright/test": "^1.59.1",
		"@tailwindcss/vite": "^4.2.1",
		"@tanstack/devtools-vite": "^0.6.0",
		"@testcontainers/postgresql": "^11.12.0",
		"@types/node": "^25.4.0",
		"@types/pg": "^8.18.0",
		"@types/pg-copy-streams": "^1.2.5",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@varlock/azure-key-vault-plugin": "^0.0.6",
		"@vercel/functions": "^3.4.3",
		"@vitejs/plugin-react": "^6.0.1",
		"@vitest/browser": "^4.1.4",
		"@vitest/browser-playwright": "^4.0.18",
		"@vitest/ui": "4.1.4",
		"babel-plugin-react-compiler": "^1.0.0",
		"drizzle-kit": "^0.31.9",
		"drizzle-orm": "^0.45.1",
		"drizzle-seed": "^0.3.1",
		"msw": "^2.13.4",
		"pg": "^8.20.0",
		"pg-copy-streams": "^7.0.0",
		"tailwindcss": "^4.2.1",
		"testcontainers": "^11.12.0",
		"tw-animate-css": "^1.4.0",
		"typescript": "6.0.2",
		"varlock": "^0.7.2",
		"vite": "^8.0.8",
		"vitest": "^4.1.4",
		"vitest-browser-react": "^2.0.5",
		"web-vitals": "^5.1.0",
		"zod": "^4.3.6"
	}
}
