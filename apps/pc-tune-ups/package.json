{
	"name": "pc-tune-ups",
	"private": true,
	"version": "0.0.0",
	"type": "module",
	"imports": {
		"#/*": "./src/*"
	},
	"scripts": {
		"build": "vite build",
		"dev": "vite dev --port 3000",
		"serve": "vite preview",
		"start": "node .output/server/index.mjs",
		"typecheck": "tsc --noEmit",
		"lint": "oxlint --type-aware --max-warnings=0",
		"test": "vitest run",
		"test:unit": "vitest run --project unit",
		"test:integration": "vitest run --project browser --project server",
		"test:watch": "vitest --watch",
		"e2e": "node --experimental-strip-types ../../scripts/src/aamini.ts e2e pc-tune-ups",
		"e2e:staging": "BASE_URL=https://pc-tune-ups.ariaamini.com pnpm playwright test",
		"e2e:update": "node --experimental-strip-types ../../scripts/src/aamini.ts e2e pc-tune-ups --update-snapshots",
		"report": "playwright show-report",
		"verify": "turbo run build test typecheck e2e"
	},
	"dependencies": {
		"@aamini/ui": "workspace:*",
		"@fontsource-variable/dm-sans": "^5.2.8",
		"@radix-ui/react-separator": "^1.1.8",
		"@radix-ui/react-slot": "^1.2.4",
		"@tanstack/react-query": "^5.90.21",
		"@tanstack/react-router": "^1.166.7",
		"@tanstack/react-router-devtools": "^1.166.7",
		"@tanstack/react-router-ssr-query": "^1.166.7",
		"@tanstack/react-start": "^1.166.7",
		"@tanstack/router-plugin": "^1.166.7",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"lucide-react": "^1.8.0",
		"nitro": "latest",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"tailwind-merge": "^3.5.0"
	},
	"devDependencies": {
		"@aamini/config-testing": "workspace:*",
		"@aamini/config-typescript": "workspace:*",
		"@aamini/config-vite": "workspace:*",
		"@playwright/test": "^1.59.1",
		"@tailwindcss/vite": "^4.2.1",
		"@tanstack/devtools-vite": "^0.6.0",
		"@types/node": "^25.4.0",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.1",
		"@vitest/browser": "^4.1.4",
		"babel-plugin-react-compiler": "^1.0.0",
		"tailwindcss": "^4.2.1",
		"tw-animate-css": "^1.4.0",
		"typescript": "6.0.2",
		"varlock": "^0.7.2",
		"vite": "^8.0.8",
		"vite-plugin-svgr": "^5.2.0",
		"vitest": "^4.1.4",
		"vitest-browser-react": "^2.0.5"
	}
}
